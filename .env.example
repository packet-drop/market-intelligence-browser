# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Required in production. Generate a long random secret and send it as:
# Authorization: Bearer <SERVICE_API_KEY>
SERVICE_API_KEY=replace-with-a-long-random-secret

# CORS Configuration
CORS_ORIGIN=*

# Playwright Configuration
PLAYWRIGHT_HEADLESS=true

# Seeking Alpha session support (disabled by default)
SEEKING_ALPHA_ENABLED=false
SEEKING_ALPHA_SESSION_PATH=/data/seeking-alpha-session.enc
# Generate with: openssl rand -base64 32
SEEKING_ALPHA_SESSION_ENCRYPTION_KEY=
# Use a different long random secret from SERVICE_API_KEY. Required only while import is enabled.
SEEKING_ALPHA_SESSION_ADMIN_KEY=
SEEKING_ALPHA_SESSION_IMPORT_ENABLED=false
SEEKING_ALPHA_MAX_QUEUE_SIZE=10
SEEKING_ALPHA_MIN_NAVIGATION_INTERVAL_MS=5000
SEEKING_ALPHA_NAVIGATION_TIMEOUT_MS=30000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
